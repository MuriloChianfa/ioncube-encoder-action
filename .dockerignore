# Docker ignore patterns for IonCube Encoder Action

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
*.lcov

# Build artifacts
dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# GitHub
.github/

# Documentation (optional, uncomment to exclude)
# *.md
# !DOCKER_TESTING.md

# Test documentation files
TESTS_READY.md

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Badge files
badges/
