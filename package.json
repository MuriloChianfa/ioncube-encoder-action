{
  "name": "ioncube-encoder-action",
  "description": "Github action to automate IonCube encoding for your PHP project.",
  "version": "3.0.0",
  "author": "MuriloChianfa <murilo.chianfa@outlook.com>",
  "private": true,
  "homepage": "https://github.com/MuriloChianfa/ioncube-encoder-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuriloChianfa/ioncube-encoder-action.git"
  },
  "bugs": {
    "url": "https://github.com/MuriloChianfa/ioncube-encoder-action/issues"
  },
  "keywords": [
    "Actions",
    "Ioncube",
    "Laravel",
    "PHP"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx ncc build src/index.js -o dist --source-map --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "test": "npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package",
    "prepare": "husky"
  },
  "license": "MIT",
  "jest": {
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "moduleNameMapper": {
      "^@actions/core$": "<rootDir>/__mocks__/@actions/core.js"
    }
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^2.0.0",
    "tar": "^7.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.4",
    "@babel/preset-env": "^7.29.2",
    "@vercel/ncc": "^0.38.4",
    "babel-preset-jest": "^30.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{js,json,yml,yaml,md}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ]
  }
}
